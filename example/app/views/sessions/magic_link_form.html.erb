<div class="card">
  <h1>Magic Link</h1>
  <p class="text-muted mb-16">Enter your email and we'll send you a sign-in link.</p>

  <%= form_with(url: send_magic_link_path, method: :post) do %>
    <div>
      <label for="email">Email</label>
      <input type="email" name="email" id="email" required>
    </div>

    <input type="submit" value="Send Magic Link">
  <% end %>

  <hr>
  <p class="text-center text-muted">
    <a href="<%= new_session_path %>">Back to sign in</a>
  </p>
</div>
